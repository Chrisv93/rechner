<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Brutto Netto Rechner Deutschland</title>
<meta name="description" content="Brutto Netto Rechner Deutschland + Gehaltsvergleich.">
<style>
body {
  font-family: Arial, sans-serif;
  max-width: 900px;
  margin: 0 auto;
  padding: 20px;
  line-height: 1.6;
}
.box {
  background: #f5f7fa;
  border: 1px solid #ddd;
  padding: 20px;
  border-radius: 10px;
  margin: 20px 0;
}
.cta {
  background: #eef6ff;
  border: 1px solid #bfd7ff;
  padding: 20px;
  border-radius: 10px;
  margin: 20px 0;
}
.button {
  display: inline-block;
  padding: 12px 18px;
  background: #0a58ca;
  color: white;
  text-decoration: none;
  border-radius: 6px;
}
</style>
</head>
<body>

<h1>Brutto Netto Rechner Deutschland</h1>

<p>Berechne dein Netto Gehalt und finde Sparpotenziale.</p>

<div class="cta">
<h2>Mehr Netto behalten</h2>
<p>Vergleiche jetzt deine Fixkosten und optimiere dein Einkommen.</p>
<a href="https://www.check24.de/" target="_blank" rel="nofollow sponsored" class="button">
Jetzt vergleichen
</a>
</div>

<div class="box">
<h2>Rechner</h2>

<input type="number" id="brutto" placeholder="Brutto z.B. 3000" style="padding:10px;width:100%;margin-bottom:10px">

<button onclick="calc()">Netto berechnen</button>

<p id="result"></p>
</div>

<div class="box">
<h2>Beliebte Seiten</h2>
<ul>
<li><a href="netto-2000-brutto.html">Netto bei 2000€</a></li>
<li><a href="netto-3000-brutto.html">Netto bei 3000€</a></li>
<li><a href="netto-4000-brutto.html">Netto bei 4000€</a></li>
</ul>
</div>

<div class="box">
<h2>Tools</h2>
<ul>
<li><a href="generator.html">Netto Seiten Generator</a></li>
</ul>
</div>

<script>
function calc(){
  let b = document.getElementById("brutto").value;
  if(!b){return;}
  let n;
  if(b <= 2000) n = b*0.74;
  else if(b <= 3000) n = b*0.72;
  else if(b <= 4000) n = b*0.70;
  else if(b <= 5000) n = b*0.68;
  else if(b <= 7000) n = b*0.66;
  else n = b*0.64;
  n = Math.round(n/50)*50;
  document.getElementById("result").innerText = b + "€ brutto ≈ " + n + "€ netto";
}
</script>

</body>
</html>
